{
  "name": "vanilla-router",
  "type": "module",
  "version": "0.1.0",
  "workspaces": [
    "playground"
  ],
  "packageManager": "bun@1.3.9",
  "description": "一个零依赖的前端路由库，支持 hash/history，适用于原生 JS 项目。",
  "author": "Drswith <drswith@outlook.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Drswith/vanilla-router.git"
  },
  "keywords": [
    "router",
    "vanilla",
    "history",
    "hash",
    "前端路由",
    "javascript"
  ],
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "dev": "bun --cwd playground dev",
    "build": "tsdown",
    "build:only": "tsdown",
    "build:watch": "tsdown --watch",
    "preview": "bun --cwd playground preview",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test:coverage": "vitest run --coverage",
    "postinstall": "npx simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.11.0",
    "@antfu/ni": "^24.3.0",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "3.1.3",
    "eslint": "^9.23.0",
    "eslint-plugin-format": "^1.0.1",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "simple-git-hooks": "^2.13.0",
    "terser": "^5.39.0",
    "tsdown": "^0.14.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-inspect": "^0.8.9",
    "vitest": "^3.1.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
